{
  "manifest_version": 3,
  "name": "EVAN",
  "version": "0.1.0",
  "description": "Compare ChatGPT and Gemini responses side by side using your existing logged-in accounts.",

  "action": {
    "default_title": "EVAN"
  },

  "background": {
    "service_worker": "background.js"
  },

  "permissions": [
    "tabs",
    "scripting",
    "storage"
  ],

  "host_permissions": [
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*"
  ],

  "content_scripts": [
    {
      "matches": [
        "https://chatgpt.com/*",
        "https://chat.openai.com/*"
      ],
      "js": [
        "providers/chatgpt.js"
      ],
      "run_at": "document_idle"
    },
    {
      "matches": [
        "https://gemini.google.com/*"
      ],
      "js": [
        "providers/gemini.js"
      ],
      "run_at": "document_idle"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": [
        "dashboard.html",
        "dashboard.css",
        "dashboard.js"
      ],
      "matches": [
        "<all_urls>"
      ]
    }
  ]
}